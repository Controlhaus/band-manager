# ---- Public URL of the app (single source of truth) ----
APP_URL=https://band.example.com

# Domain for Caddy only. MUST match the host in APP_URL.
APP_DOMAIN=band.example.com

# ---- Database ----
POSTGRES_PASSWORD=change-me
POSTGRES_USER=band
POSTGRES_DB=band
DATABASE_URL=postgresql://band:change-me@db:5432/band?schema=public

# ---- Auth ----
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=generate-64-hex

# ---- SMTP (email) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Band Manager <noreply@example.com>"

# ---- First-run bootstrap superadmin ----
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ---- Uploads ----
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=25

# ---- Timezone ----
# Default IANA timezone for new acts.
DEFAULT_TZ=Europe/Berlin

# ---- Seed ----
# Set to true to seed a demo act with songs, members and calendar entries.
SEED_DEMO=false

# ---- Scheduler ----
# Enable the in-process deadline-reminder cron job (§17.5). In a single-node
# deployment set this to true. In multi-container setups enable on ONE instance.
ENABLE_SCHEDULER=true
